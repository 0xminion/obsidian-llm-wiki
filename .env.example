# obsidian-llm-wiki configuration
# Copy to your vault root as .env and edit values as needed.

# ── LLM Provider ───────────────────────────────────────────────────────
# Supported: ollama (local), openai (any OpenAI-compatible endpoint)
LLM_PROVIDER=ollama

# Ollama: host URL for the local Ollama server
LLM_HOST=http://localhost:11434

# Model name (varies by provider — check your installed models)
LLM_MODEL=gemma3:27b

# API key — only needed for openai-compatible providers (leave empty for Ollama)
# LLM_API_KEY=sk-...

# Request timeout in milliseconds (default: 30 minutes for long synthesis)
LLM_TIMEOUT_MS=1800000

# ── Vault ──────────────────────────────────────────────────────────────
# Path to your Obsidian vault root
VAULT_PATH=$HOME/MyVault

# ── Content thresholds ─────────────────────────────────────────────────
# Sources below MIN or above MAX are skipped or truncated
MAX_SOURCE_CHARS=1000000
MIN_SOURCE_CHARS=50

# ── Concurrency ────────────────────────────────────────────────────────
# Number of parallel LLM calls during synthesis
COMPILE_CONCURRENCY=3

# ── Language ───────────────────────────────────────────────────────────
# Output language for summaries and concepts (en, zh, or empty for auto-detect)
OUTPUT_LANGUAGE=

# ── Retry ──────────────────────────────────────────────────────────────
RETRY_COUNT=3
RETRY_BASE_MS=1000
RETRY_MULTIPLIER=4

# ── Quality gates ──────────────────────────────────────────────────────
# Minimum body chars for concepts, entries, and clippings to pass quality gate
CONCEPT_MIN_BODY_CHARS=800
ENTRY_MIN_BODY_CHARS=500
CLIPPING_MIN_BODY_CHARS=500