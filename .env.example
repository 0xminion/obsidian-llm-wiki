# API Keys — get these from the respective services
TRANSCRIPT_API_KEY=
SUPADATA_API_KEY=
ASSEMBLYAI_API_KEY=

# Vault path
VAULT_PATH=$HOME/MyVault

# Agent command (hermes or claude)
AGENT_CMD=hermes

# Parallelism (number of concurrent write agents)
PARALLEL=3

# Timeouts (seconds)
EXTRACT_TIMEOUT=45
AGENT_TIMEOUT=900
PLAN_TIMEOUT=600

# Content limits (chars — controls token usage per batch)
MAX_CONTENT_PER_SOURCE=8000
MAX_TOTAL_CONTENT=15000
MAX_CONTENT_INSIGHTS=6000

# Whisper language (empty = auto-detect)
WHISPER_LANGUAGE=

# QMD semantic search
QMD_CMD=qmd
QMD_COLLECTION=concepts

# QMD MCP HTTP transport (recommended for long-lived server)
# Set to "true" to use the QMD MCP server for embeddings/search.
# QMD must be running via: qmd mcp --http --port 8181
# QMD handles indexing, embedding, and search — no Ollama needed for search.
USE_QMD_MCP=true
QMD_MCP_URL=http://localhost:8181

# ─── LLM Provider Configuration ───────────────────────────────────────────────
# Choose your provider: ollama (default), openrouter, hermes
LLM_PROVIDER=ollama

# Generation model (required for openrouter; overrides Ollama defaults)
# Examples:
#   Ollama:    minimax-m2.7:cloud, qwen3.6-plus, llama3.3:70b
#   OpenRouter: qwen/qwen3-30b-a3b:free, anthropic/claude-sonnet-4
LLM_MODEL=

# API key (required for OpenRouter; ignored for Ollama)
LLM_API_KEY=

# Base URL override (optional — defaults shown below)
# LLM_BASE_URL=http://localhost:11434        # Ollama default
# LLM_BASE_URL=https://openrouter.ai/api/v1  # OpenRouter default
LLM_BASE_URL=

# Request timeout in seconds
LLM_TIMEOUT=60

# Embedding model (Ollama only; kept separate from generation provider)
EMBED_MODEL=qwen3-embedding:0.6b
EMBED_BASE_URL=

# Legacy Ollama settings (still work when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_INSIGHT_MODEL=minimax-m2.7:cloud
OLLAMA_FILENAME_MODEL=minimax-m2.7:cloud
