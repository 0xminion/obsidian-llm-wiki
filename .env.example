# obsidian-llm-wiki configuration
# Copy to your vault root as .env and edit values as needed.

# ── LLM Provider ───────────────────────────────────────────────────────
# Supported: ollama (local), openai (any OpenAI-compatible endpoint)
LLM_PROVIDER=ollama

# Ollama: host URL for the local Ollama server
LLM_HOST=http://localhost:11434

# Model name (varies by provider — check your installed models)
LLM_MODEL=gemma3:27b

# API key — only needed for openai-compatible providers (leave empty for Ollama)
# LLM_API_KEY=sk-...

# Request timeout in milliseconds (default: 30 minutes for long synthesis)
LLM_TIMEOUT_MS=1800000

# Context window in tokens. Keep this aligned with the selected model/provider.
LLM_CONTEXT_WINDOW=256000

# ── Vault ──────────────────────────────────────────────────────────────
# Path to your Obsidian vault root
VAULT_PATH=$HOME/MyVault

# ── Content thresholds ─────────────────────────────────────────────────
# Sources below MIN or above MAX are skipped or truncated
MAX_SOURCE_CHARS=1000000
MIN_SOURCE_CHARS=50

# ── Concurrency ────────────────────────────────────────────────────────
# Number of parallel LLM calls during synthesis
COMPILE_CONCURRENCY=3

# ── Language ───────────────────────────────────────────────────────────
# Output language for summaries and concepts (en, zh, or empty for auto-detect)
OUTPUT_LANGUAGE=

# ── Retry ──────────────────────────────────────────────────────────────
RETRY_COUNT=3
RETRY_BASE_MS=1000
RETRY_MULTIPLIER=4

# ── Synthesis mode ──────────────────────────────────────────────────────
# "single" = one LLM call per source (default, fast)
# "two_pass" = extract skeleton + expand each concept (deep, slow)
SYNTHESIS_MODE=single

# Two-pass source chunking boundary (characters).
CHUNK_SIZE=30000

# ── Quality gates ──────────────────────────────────────────────────────
# Minimum body chars for concepts, entries, and clippings to pass quality gate
CONCEPT_MIN_BODY_CHARS=1200
ENTRY_MIN_BODY_CHARS=500
CLIPPING_MIN_BODY_CHARS=500

# ── Semantic features (optional) ────────────────────────────────────────
# Requires an Ollama embedding model at LLM_HOST. Use a multilingual model
# when your vault contains both Chinese and English concepts.
EMBEDDINGS_ENABLED=false
EMBEDDING_MODEL=embeddinggemma:300m
SIMILARITY_DEDUP_THRESHOLD=0.85
MOC_ASSIGNMENT_THRESHOLD=0.55

# ── Bounded document and HTML extraction ─────────────────────────────────
MAX_DOCUMENT_BYTES=50000000
MAX_DOCUMENT_CANDIDATES=10
PARSER_TIMEOUT_SECONDS=120
MAX_PARSER_STDOUT_BYTES=1000000
MAX_PARSER_STDERR_BYTES=16384

# Maximum response size (bytes) for generic HTML extraction. Responses above
# this cap are rejected while streaming rather than buffered in full.
MAX_HTML_BYTES=10000000

# ── Optional extraction services ────────────────────────────────────────
# Enable scholarly metadata fallbacks (Semantic Scholar, OpenAlex, arXiv,
# Crossref) when normal extraction fails or produces a stub.
DEEP_SEARCH_FALLBACK=false
# Optional Netscape-format cookie file for yt-dlp on age/consent-gated videos.
# YOUTUBE_COOKIES_FILE=/absolute/path/to/cookies.txt
# ASSEMBLYAI_API_KEY=...
# PODCAST_INDEX_API_KEY=...
# PODCAST_INDEX_API_SECRET=...
# Optional SOCKS/HTTP proxy for extraction. Do not set a global proxy unless
# you deliberately want every process on the host routed through it.
# RESIDENTIAL_PROXY_URL=socks5h://host:port