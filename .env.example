# LLM Provider
LLM_PROVIDER=ollama
# LLM_API_KEY=          # for openai/custom providers

# OKF version target
OKF_VERSION=0.1

# LLM Provider — Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_TIMEOUT_MS=1800000

# Embedding
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b

# Vault
VAULT_PATH=$HOME/MyVault

# Content
MAX_SOURCE_CHARS=1000000
MIN_SOURCE_CHARS=50
PROMPT_BUDGET_CHARS=200000

# Concurrency
COMPILE_CONCURRENCY=3

# Language (en, zh, or empty for auto-detect)
LLMWIKI_OUTPUT_LANGUAGE=

# Provider override
LLMWIKI_PROVIDER=ollama

# Retry
RETRY_COUNT=3
RETRY_BASE_MS=1000
RETRY_MULTIPLIER=4

# Quality gates
CONCEPT_MIN_BODY_CHARS=800
ENTRY_MIN_BODY_CHARS=500
CLIPPING_MIN_BODY_CHARS=500